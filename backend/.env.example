# Copy to .env and fill in actual values. Never commit .env.

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# PostgreSQL
# Local testing against Railway Postgres: copy the "Postgres Connection URL"
# from Railway -> your Postgres plugin -> Connect tab.
# On Railway itself, reference the plugin variable: ${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql://user:password@host:port/database

# Server
PORT=3001
NODE_ENV=development
